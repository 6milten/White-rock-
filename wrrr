<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>White Rock Boathouse — Public Accountability</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --navy:#003087;--blue:#005bbb;--light-blue:#e8f0fb;--mid-blue:#d0e4f7;
      --red:#b82020;--gold:#c8900a;--dark:#16213e;--gray:#4a4a5a;
      --light:#f5f7fa;--white:#fff;--border:#cdd8ec;
    }
    body{font-family:'Segoe UI',system-ui,sans-serif;color:var(--dark);background:var(--white);line-height:1.7}

    /* ── ALERT BANNER ── */
    .alert-banner{background:var(--red);color:#fff;text-align:center;padding:11px 20px;font-size:.875rem;font-weight:600;letter-spacing:.03em}

    /* ── HEADER ── */
    header{background:var(--navy);padding:32px 40px 0}
    .hdr{max-width:1080px;margin:0 auto}
    .hdr-eyebrow{font-size:.72rem;color:#9ab8e0;text-transform:uppercase;letter-spacing:.14em;margin-bottom:5px}
    .hdr-title{font-size:1.85rem;font-weight:700;color:#fff;line-height:1.25;margin-bottom:8px}
    .hdr-sub{font-size:.95rem;color:#b8cfe8;margin-bottom:30px}
    nav{display:flex;gap:0;border-top:1px solid rgba(255,255,255,.15);overflow-x:auto}
    nav button{background:transparent;border:none;color:#b8cfe8;padding:14px 20px;font-size:.83rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;cursor:pointer;border-bottom:3px solid transparent;white-space:nowrap;transition:color .2s,background .2s,border-color .2s}
    nav button:hover{color:#fff;background:rgba(255,255,255,.07)}
    nav button.active{color:#fff;border-bottom-color:var(--gold)}

    /* ── MAIN ── */
    main{max-width:1080px;margin:0 auto;padding:0 24px 70px}
    .tab-panel{display:none}
    .tab-panel.active{display:block}

    /* ── HERO ── */
    .hero{background:linear-gradient(135deg,#dce9f8 0%,#eef4fb 100%);border-left:5px solid var(--navy);padding:36px 40px;margin:40px 0 34px;border-radius:4px}
    .hero h1{font-size:1.65rem;font-weight:700;color:var(--navy);line-height:1.3;margin-bottom:12px}
    .hero p{font-size:1rem;color:var(--gray);max-width:760px}

    /* ── SECTION LABELS ── */
    .eyebrow{font-size:.72rem;color:var(--blue);letter-spacing:.14em;text-transform:uppercase;font-weight:700;margin-bottom:5px}
    h2{font-size:1.4rem;font-weight:700;color:var(--navy);margin-bottom:16px}
    h3{font-size:1rem;font-weight:700;color:var(--navy);margin-bottom:8px}

    /* ── ISSUE NUMBER HEADER ── */
    .issue-header{display:flex;align-items:flex-start;gap:20px;margin:40px 0 20px}
    .issue-num{width:52px;min-width:52px;height:52px;background:var(--navy);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.3rem;font-weight:700;flex-shrink:0}
    .issue-header-text .eyebrow{margin-bottom:2px}
    .issue-header-text h2{margin-bottom:0}
    hr.divider{border:none;border-top:1px solid var(--border);margin:44px 0}

    /* ── CARD ── */
    .card{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:24px 28px;margin-bottom:22px;box-shadow:0 2px 8px rgba(0,48,135,.05)}
    .card.top-blue{border-top:4px solid var(--navy)}
    .card.top-red{border-top:4px solid var(--red)}
    .card p{color:var(--gray);font-size:.94rem;margin-top:8px}
    .card p+p{margin-top:10px}
    .tag{display:inline-block;font-size:.72rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:3px 11px;border-radius:20px;margin-bottom:8px}
    .tag-red{background:#fde8e8;color:#8b1010;border:1px solid #f0bbbb}
    .tag-yellow{background:#fff3cd;color:#7a5800;border:1px solid #e8d070}
    .tag-blue{background:#dce9f8;color:#003087;border:1px solid #a8c8f0}

    /* ── CALLOUT BOXES ── */
    .callout{padding:20px 24px;margin:22px 0;border-radius:0 4px 4px 0}
    .callout-gold{background:#fdf6e3;border-left:5px solid var(--gold)}
    .callout-red{background:#fdf0ee;border-left:5px solid var(--red)}
    .callout-blue{background:#e8f0fb;border-left:5px solid var(--navy)}
    .callout strong{display:block;font-size:.88rem;text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px}
    .callout-gold strong{color:#7a5800}
    .callout-red strong{color:var(--red)}
    .callout-blue strong{color:var(--navy)}
    .callout p{font-size:.93rem;color:var(--gray)}

    /* ── STEP FLOW (Audit trail) ── */
    .step-flow{margin:24px 0 32px}
    .step{display:flex;gap:16px;margin-bottom:6px;position:relative}
    .step-line{display:flex;flex-direction:column;align-items:center}
    .step-dot{width:36px;min-width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;color:#fff;background:var(--navy);flex-shrink:0}
    .step-dot.warn{background:var(--red)}
    .step-connector{width:2px;flex:1;min-height:20px;background:var(--border);margin:4px 0}
    .step-body{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:16px 20px;flex:1;margin-bottom:16px}
    .step-body .step-date{font-size:.72rem;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
    .step-body h3{font-size:.97rem;margin-bottom:4px}
    .step-body p{font-size:.88rem;color:var(--gray)}

    /* ── EMAIL DISPLAY ── */
    .email-wrap{background:var(--white);border:1px solid var(--border);border-radius:6px;overflow:hidden;margin:22px 0;box-shadow:0 2px 10px rgba(0,0,0,.07)}
    .email-head{background:var(--light);border-bottom:1px solid var(--border);padding:16px 22px}
    .email-from{font-weight:700;color:var(--dark);font-size:.95rem}
    .email-meta{font-size:.82rem;color:var(--gray);line-height:1.7;margin-top:3px}
    .email-subject{font-size:1.05rem;font-weight:700;color:var(--navy);margin-top:8px}
    .email-body{padding:22px 26px;font-size:.94rem;color:var(--gray);line-height:1.85}
    .email-body p{margin-bottom:14px}
    .email-sig{font-size:.88rem;color:var(--dark);border-top:1px solid var(--border);margin-top:16px;padding-top:14px}
    .email-sig strong{color:var(--navy)}
    .evidence-label{font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#fff;background:var(--navy);display:inline-block;padding:4px 12px;border-radius:3px;margin-bottom:10px}

    /* ── 3-CARD GRID (HOME) ── */
    .three-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:22px;margin:24px 0 32px}
    .three-card{background:var(--white);border:1px solid var(--border);border-top:4px solid var(--navy);border-radius:6px;padding:24px;box-shadow:0 2px 8px rgba(0,48,135,.06)}
    .three-card .icon{font-size:1.6rem;margin-bottom:10px}
    .three-card p{font-size:.9rem;color:var(--gray);margin-top:6px}

    /* ── TIMELINE ── */
    .timeline{position:relative;margin:28px 0}
    .timeline::before{content:'';position:absolute;left:18px;top:0;bottom:0;width:3px;background:var(--border)}
    .tl-item{display:flex;gap:22px;margin-bottom:24px;position:relative}
    .tl-dot{width:38px;min-width:38px;height:38px;border-radius:50%;background:var(--navy);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.73rem;font-weight:700;position:relative;z-index:1;flex-shrink:0}
    .tl-dot.warn{background:var(--red)}
    .tl-body{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:16px 20px;flex:1}
    .tl-date{font-size:.72rem;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
    .tl-body p{font-size:.9rem;color:var(--gray);margin-top:6px}
    .tl-link{display:inline-block;margin-top:10px;background:var(--navy);color:#fff;text-decoration:none;padding:8px 20px;border-radius:4px;font-size:.85rem;font-weight:600;transition:background .2s}
    .tl-link:hover{background:var(--blue)}

    /* ── CTA SECTION ── */
    .cta-banner{background:linear-gradient(135deg,var(--navy) 0%,#004bb5 100%);color:#fff;border-radius:8px;padding:44px 40px;text-align:center;margin-bottom:40px}
    .cta-banner h2{color:#fff;font-size:1.55rem;margin-bottom:10px}
    .cta-banner p{color:#b8cfe8;font-size:1rem;max-width:580px;margin:0 auto 26px}
    .cta-btn{display:inline-block;background:var(--gold);color:#1a1000;font-weight:700;padding:13px 34px;border-radius:4px;text-decoration:none;font-size:.95rem;letter-spacing:.04em;border:none;cursor:pointer;font-family:inherit;transition:background .2s}
    .cta-btn:hover{background:#e0a010}

    .demands-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;margin:24px 0 36px}
    .demand{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:20px 22px}
    .demand .icon{font-size:1.4rem;margin-bottom:8px}
    .demand p{font-size:.88rem;color:var(--gray);margin-top:6px}

    .template-box{background:var(--light);border:1px solid var(--border);border-radius:6px;padding:26px 30px;margin:28px 0}
    .template-text{background:#fff;border:1px solid var(--border);border-radius:4px;padding:18px 22px;font-size:.9rem;color:var(--gray);line-height:1.85;font-style:italic}
    .template-text p{margin-bottom:12px}

    .council-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;margin:22px 0 36px}
    .council-card{background:#fff;border:1px solid var(--border);border-radius:6px;padding:20px 22px}
    .council-card .dist{font-size:.72rem;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
    .council-card h3{font-size:.97rem}
    .council-card .info{font-size:.85rem;color:var(--gray);margin-top:10px;line-height:1.65}
    .council-card a{color:var(--blue);text-decoration:none}
    .council-card a:hover{text-decoration:underline}

    /* ── ARTICLE CARD ── */
    .article-card{background:#fff;border:1px solid var(--border);border-radius:6px;overflow:hidden;margin:20px 0}
    .article-card-head{background:var(--light);border-bottom:1px solid var(--border);padding:22px 28px}
    .article-card-head h3{font-size:1.1rem;color:var(--dark);margin-top:6px;line-height:1.4}
    .article-pub{font-size:.8rem;color:var(--gray)}
    .article-card-body{padding:22px 28px;font-size:.94rem;color:var(--gray);line-height:1.85}
    .article-card-body p{margin-bottom:14px}
    .read-btn{display:inline-block;background:var(--navy);color:#fff;text-decoration:none;padding:10px 24px;border-radius:4px;font-size:.88rem;font-weight:600;margin-top:6px;transition:background .2s}
    .read-btn:hover{background:var(--blue)}

    /* ── FOOTER ── */
    footer{background:var(--dark);color:#7a95c0;text-align:center;padding:28px 24px;font-size:.83rem;line-height:1.85}
    footer a{color:#9ab8e0}

    /* ── RESPONSIVE ── */
    @media(max-width:620px){
      header{padding:22px 18px 0}
      .hdr-title{font-size:1.35rem}
      .hero{padding:24px 20px}
      .hero h1{font-size:1.3rem}
      main{padding:0 16px 48px}
      .cta-banner{padding:30px 18px}
    }
  </style>
</head>
